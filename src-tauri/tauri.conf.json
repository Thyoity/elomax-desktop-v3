{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ELOMAX",
  "version": "0.0.9",
  "identifier": "com.ggmax.elomax",
  "build": {
    "beforeDevCommand": "npm run browser:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ELOMAX",
        "width": 1200,
        "height": 680,
        "resizable": false,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "ELOMAX, Inc.",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwMDg0MjgzMkU4NzY0RUIKUldUclpJY3VnMElJUUYrYWQ0SXMyK0tzSlhGMjZnOTB5UzJ4K0RtNEl1WnNqRmZzT2ZMTkJuRDgK",
      "endpoints": [
        "https://github.com/Thyoity/elomax-desktop-v3/releases/latest/download/latest.json"
      ]
    }
  }
}
