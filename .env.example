# Copy this file to `.env` and adjust as needed.
# Only variables prefixed with VITE_ are exposed to the frontend at build time.

# REST API host (must include /api). Defaults to production if not set.
VITE_API_BASE_URL=https://elojobmax.com.br/api

# Public website host (used for image assets, external links and files).
VITE_WEB_BASE_URL=https://elojobmax.com.br

# Pusher / Soketi credentials.
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=mt1
