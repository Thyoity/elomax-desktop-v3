# Environment files (commit only .env.example)
.env
.env.local
.env.*.local

# Tauri signing keys — must NEVER be committed. The literal `~/` folder
# below is a Windows artifact: `npx tauri signer generate -w ~/.tauri/...`
# doesn't expand `~` on Windows and creates the dir relative to the repo.
~/
*.key
*.key.pub

# Ionicons assets are synced from node_modules by scripts/sync-ionicons.mjs
# on `npm install` — no need to commit a copy.
public/ionicons/

# One-shot migration / batch helpers — see CLAUDE.md "Scripts" section.
scripts/oneshot/
